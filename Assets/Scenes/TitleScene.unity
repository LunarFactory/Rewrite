  m_text: "AI\uB97C \uD65C\uC6A9\uD55C \uAC00\uBCC0\uD615 \uB09C\uC774\uB3C4\uAC00
    \uC801\uC6A9\uB41C \uC0D8\uD50C \uAC8C\uC784\uC785\uB2C8\uB2E4.\n\uD50C\uB808\uC774\uC5B4\uB294
    \uC801\uC744 \uACA9\uD30C\uD558\uBA70 \uBCF4\uC2A4\uB97C \uCC98\uCE58\uD558\uB294
    \uAC83\uC774 \uBAA9\uD45C\uC774\uBA70,\n\uB9E4 \uD50C\uB808\uC774\uB9C8\uB2E4
    \uC801\uC758 \uAD6C\uC131\uACFC \uB4F1\uC7A5 \uC544\uC774\uD15C\uC774 \uBCC0\uB3D9\uB429\uB2C8\uB2E4.\n\n\uD50C\uB808\uC774\uC5B4\uC758
    \uC870\uC791 \uC219\uB828\uB3C4\uC5D0 \uB530\uB77C \uB09C\uC774\uB3C4\uAC00 \uBCC0\uB3D9\uD569\uB2C8\uB2E4."
